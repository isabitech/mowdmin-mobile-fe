{
  "expo": {
    "name": "mowd",
    "slug": "mowd",
    "version": "1.0.0",
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.mowd.com",
          "enableGooglePay": true
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mowd.com"
    },
    "extra": {
      "eas": {
        "projectId": "72cfc788-6399-4028-a42a-0f7bf4071fc0"
      }
    }
  }
}
