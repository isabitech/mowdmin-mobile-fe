{
  "expo": {
    "name": "Mowd Ministries",
    "slug": "mowdministries-mobile",
    "version": "1.0.0",
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.mowd.com",
          "enableGooglePay": true
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker"
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mowd.com"
    },
    "extra": {
      "eas": {
        "projectId": "b969ca6c-cdca-4142-9def-32d18410d38e"
      }
    },
    "owner": "isabitech"
  }
}
